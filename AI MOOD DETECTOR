<!DOCTYPE html>
<html>
<head>
  <title>AI Mood Detector</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #f4f4f4;
      padding: 40px;
    }
    textarea {
      width: 300px;
      height: 100px;
    }
    button {
      padding: 10px 20px;
      margin-top: 10px;
      cursor: pointer;
    }
    #result {
      font-size: 20px;
      margin-top: 20px;
    }
    canvas {
      max-width: 400px;
      margin: auto;
    }
  </style>
</head>
<body>

<h1>AI Mood Detector 😊</h1>

<textarea id="text" placeholder="Type your feelings..."></textarea><br>
<button onclick="detectMood()">Detect Mood</button>

<div id="result"></div>
<canvas id="chart"></canvas>

<script>
let chart;

async function detectMood() {
    const text = document.getElementById("text").value;

    const response = await fetch(
        "https://api-inference.huggingface.co/models/j-hartmann/emotion-english-distilroberta-base",
        {
            method: "POST",
            headers: {
                "Authorization": "Bearer YOUR_API_KEY",
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ inputs: text })
        }
    );

    const data = await response.json();

    const emotions = data[0].sort((a, b) => b.score - a.score);
    const top = emotions[0];

    document.getElementById("result").innerHTML =
        `Detected Mood: <b>${top.label}</b><br>
         Confidence: ${(top.score * 100).toFixed(2)}%`;

    const labels = emotions.map(e => e.label);
    const scores = emotions.map(e => (e.score * 100).toFixed(2));

    if (chart) chart.destroy();

    const ctx = document.getElementById('chart').getContext('2d');

    chart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Emotion %',
                data: scores
            }]
        }
    });
}
</script>

</body>
</html>
